<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/primary">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎙 Greeting Setup"
                android:textSize="24sp"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customize your voicemail greeting"
                android:textSize="14sp"
                android:textColor="#B0D4FF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Status -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Status"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/greetingStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ No greeting set"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Recording Indicator -->
        <TextView
            android:id="@+id/recordingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔴  Recording in progress..."
            android:textSize="16sp"
            android:textColor="#F44336"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:visibility="gone" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🎙 Record Greeting"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpload"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📁 Upload Greeting File"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateDefault"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🤖 Generate Default Greeting"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayGreeting"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="▶ Play Greeting"
                android:textSize="16sp"
                android:enabled="false"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetGreeting"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🗑 Reset Greeting"
                android:textSize="16sp"
                android:enabled="false"
                android:textColor="#F44336"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <!-- Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#E8F5E9"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="💡 Tip: Record a clear, friendly greeting. Supported formats: MP3, WAV, M4A. The greeting plays to callers before the beep."
                android:textSize="13sp"
                android:textColor="#2E7D32"
                android:lineSpacingExtra="4dp" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
